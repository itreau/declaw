SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_APP_TOKEN=xapp-your-app-token-here
OLLAMA_URL=http://host.docker.internal:11434
MODEL=qwen2.5-coder:14b
BACKEND=opencode
MAX_OUTPUT_LENGTH=200
OUTPUT_DIR=./output
TOOL_TIMEOUT=120

# GitHub PAT Token (Required for /github commands)
# Create at: https://github.com/settings/tokens
# Required scopes: 'public_repo' (read-only), 'repo:write' (PR/issue creation), or 'repo' (full access)
# See docs/GITHUB_REST_API.md for operation-specific scopes
GITHUB_TOKEN=ghp_your_token_here

# Workspace directory for git operations (optional)
# Defaults to ./output/workspace locally or /workspace in container
# WORKSPACE_DIR=/workspace
